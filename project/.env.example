# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000

# LLM Provider: ollama | deepseek
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b-instruct-2507-q4_K_M
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0
DEEPSEEK_API_KEY=your-deepseek-api-key

# RAGAS judge max completion tokens (default 4096; increase if context_recall fails)
JUDGE_MAX_TOKENS=4096

# Retrieval (MODULAR-RAG style): dense + sparse -> RRF -> fusion_top_k -> rerank
DENSE_TOP_K=20
SPARSE_TOP_K=20
FUSION_TOP_K=10
RRF_K=60

# Rerank (second-stage precision). Provider: none | cross_encoder | llm
RERANK_ENABLED=true
RERANK_PROVIDER=cross_encoder
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_MULTIPLIER=2

# Layered retrieval confidence (rerank -> optional LLM -> agent routing)
CONFIDENCE_ENABLED=true
CONFIDENCE_SECONDARY_RETRIEVAL=true
CONFIDENCE_SECONDARY_MULTIPLIER=2
CONFIDENCE_SECONDARY_DENSE_TOP_K=30
CONFIDENCE_SECONDARY_SPARSE_TOP_K=30
CONFIDENCE_RERANK_LOW_THRESHOLD=-2.0
# Rerank top score -> preliminary 0-10 (linear, continuous). Defaults: -5.0 -> 0, 10.0 -> 10.
CONFIDENCE_RERANK_SCORE_MIN=-5.0
CONFIDENCE_RERANK_SCORE_MAX=10.0
# Preliminary 2–8 -> LLM fine eval; final score tiers: high>=7, medium 3–7 (Agent re-search), low<3 (web).
CONFIDENCE_RERANK_GRAY_LOW=2
CONFIDENCE_RERANK_GRAY_HIGH=8
CONFIDENCE_LLM_ENABLED=true
CONFIDENCE_LLM_MAX_CONTEXT_CHUNKS=5
CONFIDENCE_HIGH_THRESHOLD=7
CONFIDENCE_LOW_THRESHOLD=3
CONFIDENCE_AGENT_RETRY_ON_MEDIUM=true
CONFIDENCE_MAX_AGENT_RETRIES=1
CONFIDENCE_WEB_SEARCH_ON_LOW=true
CONFIDENCE_MAX_WEB_SEARCH_RETRIES=1

# Web search fallback (DuckDuckGo via ddgs, no API key)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

# Query routing: direct LLM answer vs RAG retrieval
QUERY_ROUTING_ENABLED=true
QUERY_ROUTING_USE_RULES=true
QUERY_ROUTING_LLM_THRESHOLD=0.7
# When true: rule miss defaults to RAG without calling routing LLM
QUERY_ROUTING_RULES_ONLY=false

# Ingestion Pipeline (parse → clean → chunk → enrich → index)
INGESTION_EXTRACT_IMAGES=true
# Markdown: resolves ![](relative/path) from the uploaded .md file's folder, copies to data/images/, replaces with [IMAGE: id]
INGESTION_DOC_CONVERT_TO_DOCX=true
INGESTION_CHUNK_REFINER_USE_LLM=false
INGESTION_METADATA_ENRICHER_USE_LLM=false
# Parent chunks: LLM-generated summary + tags (title stays rule-based)
INGESTION_PARENT_METADATA_USE_LLM=true
INGESTION_PARENT_MAX_TAGS=10
# INGESTION_PARENT_LLM_MAX_CHARS=4000
INGESTION_LLM_MAX_WORKERS=5
INGESTION_VISION_MAX_WORKERS=3

# Image understanding — OCR + Vision LLM (Transform / ImageCaptioner)
# OCR: pip install paddlepaddle -i https://www.paddlepaddle.org.cn/packages/stable/cpu/ && pip install paddleocr
OCR_ENABLED=false
OCR_PROVIDER=paddle
OCR_LANG=ch
# ocr_only | vlm_only | ocr_then_vlm
IMAGE_UNDERSTANDING_MODE=ocr_then_vlm

# Scanned PDF — Load stage: render each page → OCR → VLM structure
INGESTION_PDF_SCAN_OCR=true
INGESTION_PDF_SCAN_MODE=auto
INGESTION_PDF_SCAN_DPI=200
INGESTION_PDF_SCAN_TEXT_THRESHOLD=50

# Image captioning — uses Ollama vision model, independent of LLM_PROVIDER above
# Requires: ollama serve running + `ollama pull llava` (or your chosen vision model)
VISION_LLM_ENABLED=false
VISION_LLM_PROVIDER=ollama
VISION_LLM_MODEL=llava
VISION_LLM_BASE_URL=http://127.0.0.1:11434
# VISION_LLM_API_KEY=          # only for VISION_LLM_PROVIDER=openai

# Semantic chunking (uses DENSE_MODEL for contextual embeddings during ingestion)
# PARENT_CONTEXT_BUFFER=2
# CHILD_CONTEXT_BUFFER=1
# PARENT_SEMANTIC_PERCENTILE=90
# CHILD_SEMANTIC_PERCENTILE=70
